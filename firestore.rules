rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /admin/withdrawal-settings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admin/crypto-addresses {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isSafeUserCreate();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && isSafeUserUpdate());
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /withdrawal-requests/{requestId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    // Accounts used by admin panel to mirror user balances
    match /accounts/{accountId} {
      // Full access for admins
      allow read, write: if isAdmin();

      // Owners can read their own account
      allow read: if isSignedIn() && (
        accountId == request.auth.uid ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );

      // Owners can create their own account doc if needed
      allow create: if isSignedIn() && (
        accountId == request.auth.uid ||
        (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
      );
    }

    match /conversations/{conversationId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && conversationUserId(conversationId) == request.auth.uid;
      allow create: if isSignedIn()
        && conversationUserId(conversationId) == request.auth.uid
        && request.resource.data.senderType == 'user'
        && request.resource.data.senderId == request.auth.uid;
    }

    match /kyc/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /kycRequests/{requestId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid ||
        requestId == request.auth.uid
      );
      allow read, update: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        requestId == request.auth.uid
      );
    }

    match /trades/{tradeId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /settings/{settingsId} {
      allow read, write: if isAdmin();
    }

    match /funding/{fundingId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /pending_deposits/{depositId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /walletImports/{importId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.uid == request.auth.uid
      );
    }

    match /deletedUsers/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /user_sessions/{sessionId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId}/transactions/{transactionId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isSafeUserCreate() {
      return !(request.resource.data.role == 'admin');
    }

    function isSafeUserUpdate() {
      return !request.resource.data.keys().hasAny(['role']) || request.resource.data.role == resource.data.role;
    }

    function conversationUserId(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId;
    }
  }
}
